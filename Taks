    document.getElementById('postId').value=p.id;
    document.getElementById('postDate').value=p.date;
    document.getElementById('postPlatform').value=p.platform;
    document.getElementById('postPillar').value=p.pillar;
    document.getElementById('postIdea').value=p.idea;
    document.getElementById('postStatus').value=p.status;
    document.getElementById('postDelete').style.visibility='visible';
  } else {
    document.getElementById('postModalTitle').textContent='New post';
    document.getElementById('postId').value='';
    document.getElementById('postDate').value=presetDate||'2026-07-01';
    document.getElementById('postPlatform').value='Instagram';
    document.getElementById('postPillar').value='Drink of the Week';
    document.getElementById('postIdea').value='';
    document.getElementById('postStatus').value='planned';
    document.getElementById('postDelete').style.visibility='hidden';
  }
  setTimeout(()=>document.getElementById('postIdea').focus(),50);
}
function savePost(){
  const idea=document.getElementById('postIdea').value.trim();
  if(!idea){ document.getElementById('postIdea').focus(); return; }
  const pid=document.getElementById('postId').value;
  const data={date:document.getElementById('postDate').value,platform:document.getElementById('postPlatform').value,
    pillar:document.getElementById('postPillar').value,idea,status:document.getElementById('postStatus').value};
  if(pid){ Object.assign(state.posts.find(x=>x.id===pid),data); }
  else { state.posts.push({id:id(),...data}); }
  save(); closeModal(); renderSocial(); renderDashboard(); renderCalendar();
}
function deletePost(){ const pid=document.getElementById('postId').value; state.posts=state.posts.filter(x=>x.id!==pid); save(); closeModal(); renderSocial(); renderDashboard(); renderCalendar(); }

