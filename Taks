<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lake Roots — July 2026 Command Center</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Oswald:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --forest:#2A4A1E; --forest-deep:#1C3314; --forest-soft:#3C6129;
    --gold:#C4921A; --gold-soft:#E0B448; --gold-wash:#FBF1D8;
    --wheat:#F2E8CC; --paper:#FAF6EC; --cream:#FFFDF7; --white:#fff;
    --ink:#26251F; --ink-soft:#73705F; --ink-faint:#9b9784;
    --coffee:#6B4423; --coffee-soft:#8A5A30; --coffee-wash:#F3E7DC;
    --line:rgba(42,74,30,0.13); --line-strong:rgba(42,74,30,0.22);
    --shadow:0 1px 2px rgba(28,51,20,.05), 0 6px 18px rgba(28,51,20,.06);
    --shadow-lg:0 12px 40px rgba(28,51,20,.16);
    --ok:#3C6129; --warn:#C4921A; --danger:#9c3a2a;
    --disp:'Fraunces',Georgia,serif;
    --label:'Oswald',sans-serif;
    --body:'Inter',-apple-system,system-ui,sans-serif;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-text-size-adjust:100%}
  body{font-family:var(--body);color:var(--ink);background:var(--paper);line-height:1.5;font-size:15px}
  body::before{content:"";position:fixed;inset:0;z-index:-1;
    background:
      radial-gradient(1200px 500px at 12% -8%, rgba(196,146,26,.10), transparent 60%),
      radial-gradient(1000px 600px at 100% 0%, rgba(42,74,30,.10), transparent 55%);}
  button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
  input,textarea,select{font-family:inherit;font-size:14px;color:var(--ink)}
  .label{font-family:var(--label);text-transform:uppercase;letter-spacing:.09em;font-weight:600}
  .disp{font-family:var(--disp)}
  a{color:var(--forest);text-underline-offset:2px}

  /* ---------- Header ---------- */
  header{background:var(--forest);color:#f4efe0;position:sticky;top:0;z-index:40;
    box-shadow:0 2px 0 var(--gold), 0 8px 24px rgba(28,51,20,.18)}
  .head-inner{max-width:1240px;margin:0 auto;padding:14px 22px;display:flex;align-items:center;gap:18px;flex-wrap:wrap}
  .brand{display:flex;align-items:center;gap:13px;min-width:0}
  .mark{width:42px;height:42px;flex:none;border-radius:50%;background:var(--gold);
    display:grid;place-items:center;box-shadow:inset 0 0 0 2px rgba(255,255,255,.25)}
  .mark svg{width:24px;height:24px}
  .brand h1{font-family:var(--disp);font-weight:600;font-size:20px;line-height:1.05;letter-spacing:.2px}
  .brand .sub{font-family:var(--label);text-transform:uppercase;letter-spacing:.16em;font-size:10.5px;
    color:var(--gold-soft);font-weight:500;margin-top:2px}
  .head-tools{margin-left:auto;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .save-pill{font-family:var(--label);text-transform:uppercase;letter-spacing:.08em;font-size:10.5px;
    font-weight:600;color:#dbe6cf;background:rgba(255,255,255,.08);padding:5px 11px;border-radius:20px;
    display:inline-flex;align-items:center;gap:6px}
  .save-dot{width:7px;height:7px;border-radius:50%;background:var(--gold-soft)}
  .save-pill.saved .save-dot{background:#9fd17a}
  .ghost{color:#e9e2cf;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.14);
    padding:7px 12px;border-radius:9px;font-size:12.5px;font-weight:600;transition:.15s}
  .ghost:hover{background:rgba(255,255,255,.16)}

  /* ---------- Nav ---------- */
  nav{background:var(--cream);border-bottom:1px solid var(--line);position:sticky;top:71px;z-index:30}
  .nav-inner{max-width:1240px;margin:0 auto;padding:0 16px;display:flex;gap:2px;overflow-x:auto}
  .tab{font-family:var(--label);text-transform:uppercase;letter-spacing:.07em;font-weight:600;font-size:13px;
    color:var(--ink-soft);padding:14px 16px;border-bottom:3px solid transparent;white-space:nowrap;
    display:inline-flex;align-items:center;gap:8px;transition:.15s}
  .tab svg{width:17px;height:17px;opacity:.7}
  .tab:hover{color:var(--forest)}
  .tab.active{color:var(--forest);border-bottom-color:var(--gold)}
  .tab.active svg{opacity:1}

  main{max-width:1240px;margin:0 auto;padding:26px 22px 80px}
  .view{display:none;animation:fade .25s ease}
  .view.active{display:block}
  @keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

  .view-head{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:20px}
  .view-head h2{font-family:var(--disp);font-weight:600;font-size:30px;letter-spacing:-.3px;line-height:1}
  .view-head .lede{color:var(--ink-soft);font-size:13.5px;margin-top:7px;max-width:62ch}
  .eyebrow{font-family:var(--label);text-transform:uppercase;letter-spacing:.16em;font-size:11px;font-weight:600;
    color:var(--gold);margin-bottom:8px}

  /* ---------- Buttons ---------- */
  .btn{font-family:var(--label);text-transform:uppercase;letter-spacing:.05em;font-weight:600;font-size:12.5px;
    padding:9px 15px;border-radius:9px;display:inline-flex;align-items:center;gap:7px;transition:.15s;
    border:1px solid transparent}
  .btn svg{width:15px;height:15px}
  .btn-primary{background:var(--forest);color:#f4efe0}
  .btn-primary:hover{background:var(--forest-deep)}
  .btn-gold{background:var(--gold);color:#3a2c08}
  .btn-gold:hover{background:#b1831414;background-color:var(--gold-soft)}
  .btn-line{background:var(--white);border-color:var(--line-strong);color:var(--forest)}
  .btn-line:hover{background:var(--gold-wash)}

  /* ---------- Cards ---------- */
  .card{background:var(--white);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow)}
  .grid{display:grid;gap:18px}

  /* ---------- Dashboard ---------- */
  .dash-top{grid-template-columns:1.15fr .85fr}
  @media(max-width:860px){.dash-top{grid-template-columns:1fr}}
  .panel-pad{padding:22px}
  .panel-title{font-family:var(--label);text-transform:uppercase;letter-spacing:.1em;font-size:12.5px;
    font-weight:600;color:var(--ink-soft);display:flex;align-items:center;gap:8px;margin-bottom:16px}
  .panel-title .pt-dot{width:9px;height:9px;border-radius:2px;background:var(--gold)}

  .progress-wrap{display:flex;align-items:center;gap:26px;flex-wrap:wrap}
  .ring{position:relative;width:128px;height:128px;flex:none}
  .ring svg{transform:rotate(-90deg)}
  .ring .ring-center{position:absolute;inset:0;display:grid;place-items:center;text-align:center}
  .ring .ring-num{font-family:var(--disp);font-weight:600;font-size:34px;line-height:1;color:var(--forest)}
  .ring .ring-lab{font-family:var(--label);text-transform:uppercase;letter-spacing:.08em;font-size:10px;
    color:var(--ink-soft);font-weight:600;margin-top:3px}
  .prog-stats{display:flex;flex-direction:column;gap:11px;flex:1;min-width:180px}
  .prog-row{display:flex;align-items:center;justify-content:space-between;font-size:13.5px}
  .prog-row b{font-family:var(--disp);font-weight:600;font-size:17px}

  .balance{margin-top:6px}
  .bal-bar{height:30px;border-radius:9px;overflow:hidden;display:flex;border:1px solid var(--line);background:var(--wheat)}
  .bal-seg{display:flex;align-items:center;justify-content:center;font-family:var(--label);text-transform:uppercase;
    letter-spacing:.06em;font-size:11px;font-weight:600;color:#fff;transition:flex-basis .4s ease;white-space:nowrap;overflow:hidden}
  .bal-mkt{background:linear-gradient(180deg,var(--gold-soft),var(--gold));color:#3a2c08}
  .bal-cat{background:linear-gradient(180deg,var(--coffee-soft),var(--coffee))}
  .bal-legend{display:flex;gap:18px;margin-top:12px;font-size:12.5px;color:var(--ink-soft);flex-wrap:wrap}
  .bal-legend span{display:inline-flex;align-items:center;gap:7px}
  .swatch{width:11px;height:11px;border-radius:3px;display:inline-block}

  .stat-grid{grid-template-columns:repeat(4,1fr)}
  @media(max-width:760px){.stat-grid{grid-template-columns:repeat(2,1fr)}}
  .stat{padding:16px 16px 15px;border-radius:14px;background:var(--cream);border:1px solid var(--line);position:relative;overflow:hidden}
  .stat::before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--gold)}
  .stat.cat::before{background:var(--coffee)}
  .stat .s-num{font-family:var(--disp);font-weight:600;font-size:30px;line-height:1;color:var(--forest)}
  .stat .s-lab{font-family:var(--label);text-transform:uppercase;letter-spacing:.06em;font-size:11px;
    color:var(--ink-soft);font-weight:600;margin-top:7px}

  .focus-list,.upcoming-list{display:flex;flex-direction:column;gap:2px}
  .focus-item{display:flex;gap:12px;align-items:flex-start;padding:12px 6px;border-bottom:1px solid var(--line)}
  .focus-item:last-child{border-bottom:none}
  .fi-date{font-family:var(--label);text-transform:uppercase;font-size:11px;font-weight:600;color:var(--gold);
    width:54px;flex:none;text-align:center;line-height:1.25;padding-top:2px}
  .fi-date .d{font-family:var(--disp);font-size:19px;color:var(--forest);display:block}
  .fi-body{flex:1;min-width:0}
  .fi-title{font-weight:600;font-size:14px}
  .fi-meta{font-size:12px;color:var(--ink-soft);margin-top:2px;display:flex;gap:8px;flex-wrap:wrap;align-items:center}

  .tag{font-family:var(--label);text-transform:uppercase;letter-spacing:.05em;font-size:9.5px;font-weight:600;
    padding:3px 8px;border-radius:20px;white-space:nowrap}
  .tag-mkt{background:var(--gold-wash);color:#7a5a06}
  .tag-cat{background:var(--coffee-wash);color:var(--coffee)}
  .tag-event{background:#e7efe1;color:var(--forest)}
  .tag-shoot{background:#e9e2f3;color:#5a4178}
  .tag-social{background:#e2eef2;color:#2d6072}

  /* rhythm */
  .rhythm-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:8px}
  @media(max-width:760px){.rhythm-grid{grid-template-columns:1fr 1fr}}
  .rhythm-day{background:var(--cream);border:1px solid var(--line);border-radius:12px;padding:12px;min-height:96px}
  .rhythm-day h4{font-family:var(--label);text-transform:uppercase;letter-spacing:.06em;font-size:11.5px;
    color:var(--forest);font-weight:600;margin-bottom:6px}
  .rhythm-day .rh-text{font-size:12px;color:var(--ink-soft);line-height:1.45;border:none;background:transparent;
    width:100%;resize:none;min-height:62px;outline:none}
  .rhythm-day .rh-text:focus{color:var(--ink)}

  /* ---------- Tasks ---------- */
  .filters{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:18px}
  .seg{display:inline-flex;background:var(--white);border:1px solid var(--line-strong);border-radius:10px;overflow:hidden}
  .seg button{font-family:var(--label);text-transform:uppercase;letter-spacing:.05em;font-size:12px;font-weight:600;
    padding:8px 13px;color:var(--ink-soft);transition:.12s}
  .seg button.on{background:var(--forest);color:#f4efe0}
  .seg button.on.mkt{background:var(--gold);color:#3a2c08}
  .seg button.on.cat{background:var(--coffee);color:#fff}
  .search{flex:1;min-width:160px;max-width:280px;position:relative}
  .search input{width:100%;padding:9px 12px 9px 34px;border:1px solid var(--line-strong);border-radius:10px;background:var(--white)}
  .search svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);width:16px;height:16px;color:var(--ink-faint)}

  .tasks-cols{display:grid;grid-template-columns:1fr 1fr;gap:18px}
  @media(max-width:860px){.tasks-cols{grid-template-columns:1fr}}
  .task-col-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
  .task-col-head .tch-title{font-family:var(--disp);font-weight:600;font-size:18px;display:flex;align-items:center;gap:9px}
  .domain-dot{width:12px;height:12px;border-radius:3px}
  .dd-mkt{background:var(--gold)} .dd-cat{background:var(--coffee)}
  .task-col-head .count{font-family:var(--label);font-size:12px;color:var(--ink-soft);font-weight:600}

  .task{display:flex;gap:12px;align-items:flex-start;padding:13px 14px;background:var(--white);border:1px solid var(--line);
    border-radius:13px;margin-bottom:9px;box-shadow:var(--shadow);transition:.15s}
  .task:hover{border-color:var(--line-strong)}
  .task.done{opacity:.62;background:var(--cream)}
  .task.done .t-title{text-decoration:line-through;text-decoration-color:var(--ink-faint)}
  .check{width:22px;height:22px;flex:none;border-radius:7px;border:2px solid var(--line-strong);background:var(--white);
    margin-top:1px;display:grid;place-items:center;transition:.15s}
  .check:hover{border-color:var(--forest)}
  .check svg{width:14px;height:14px;color:#fff;opacity:0;transform:scale(.5);transition:.15s}
  .task.done .check{background:var(--ok);border-color:var(--ok)}
  .task.done .check svg{opacity:1;transform:scale(1)}
  .t-main{flex:1;min-width:0}
  .t-title{font-weight:600;font-size:14.5px;line-height:1.3}
  .t-meta{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:7px;font-size:12px;color:var(--ink-soft)}
  .t-cat{font-family:var(--label);text-transform:uppercase;letter-spacing:.04em;font-size:10px;font-weight:600}
  .t-date{display:inline-flex;align-items:center;gap:4px}
  .t-date svg{width:12px;height:12px}
  .t-notes{font-size:12.5px;color:var(--ink-soft);margin-top:7px;line-height:1.45}
  .prio{width:8px;height:8px;border-radius:50%;flex:none}
  .prio-high{background:var(--danger)} .prio-med{background:var(--gold)} .prio-low{background:var(--ink-faint)}
  .t-actions{display:flex;gap:4px;flex:none;opacity:0;transition:.15s}
  .task:hover .t-actions{opacity:1}
  .icon-btn{width:30px;height:30px;border-radius:8px;display:grid;place-items:center;color:var(--ink-soft);transition:.12s}
  .icon-btn:hover{background:var(--wheat);color:var(--forest)}
  .icon-btn svg{width:15px;height:15px}
  .add-inline{width:100%;text-align:left;padding:12px 14px;border:1.5px dashed var(--line-strong);border-radius:13px;
    color:var(--ink-soft);font-family:var(--label);text-transform:uppercase;letter-spacing:.05em;font-weight:600;font-size:12.5px;
    display:flex;align-items:center;gap:8px;transition:.15s}
  .add-inline:hover{border-color:var(--gold);color:var(--forest);background:var(--gold-wash)}
  .add-inline svg{width:16px;height:16px}

  /* ---------- Calendar ---------- */
  .cal-wrap{overflow-x:auto}
  .cal{width:100%;border-collapse:separate;border-spacing:0;min-width:720px;table-layout:fixed}
  .cal th{font-family:var(--label);text-transform:uppercase;letter-spacing:.08em;font-size:11.5px;font-weight:600;
    color:var(--ink-soft);padding:0 0 12px;text-align:left}
  .cal td{vertical-align:top;border:1px solid var(--line);height:118px;width:14.28%;padding:0;background:var(--white);position:relative}
  .cal td:first-child,.cal td.weekend{background:var(--cream)}
  .cal td.empty{background:transparent;border-color:transparent}
  .cell{padding:8px;height:100%;display:flex;flex-direction:column;cursor:pointer;transition:.12s}
  .cell:hover{background:var(--gold-wash)}
  .cell.has-today{box-shadow:inset 0 0 0 2px var(--gold)}
  .daynum{font-family:var(--disp);font-weight:600;font-size:16px;color:var(--ink);margin-bottom:5px;display:flex;justify-content:space-between;align-items:center}
  .daynum .today-pill{font-family:var(--label);font-size:8.5px;letter-spacing:.05em;background:var(--gold);color:#3a2c08;
    padding:2px 6px;border-radius:10px;text-transform:uppercase}
  .chips{display:flex;flex-direction:column;gap:3px;overflow:hidden}
  .chip{font-size:10.5px;line-height:1.25;padding:3px 6px;border-radius:6px;white-space:nowrap;overflow:hidden;
    text-overflow:ellipsis;font-weight:600;border-left:3px solid}
  .chip-mkt{background:var(--gold-wash);border-color:var(--gold);color:#7a5a06}
  .chip-cat{background:var(--coffee-wash);border-color:var(--coffee);color:var(--coffee)}
  .chip-event{background:#e7efe1;border-color:var(--forest);color:var(--forest)}
  .chip-shoot{background:#e9e2f3;border-color:#5a4178;color:#5a4178}
  .chip-social{background:#e2eef2;border-color:#2d6072;color:#2d6072}
  .chip.done{opacity:.5;text-decoration:line-through}
  .more{font-size:10px;color:var(--ink-soft);font-weight:600;padding:1px 6px}
  .cal-legend{display:flex;gap:16px;flex-wrap:wrap;margin-top:16px;font-size:12px;color:var(--ink-soft)}
  .cal-legend span{display:inline-flex;align-items:center;gap:7px}

  /* ---------- Social ---------- */
  .pillars{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:22px}
  @media(max-width:900px){.pillars{grid-template-columns:1fr 1fr}}
  .pillar{padding:13px;border-radius:12px;background:var(--white);border:1px solid var(--line);box-shadow:var(--shadow)}
  .pillar .p-n{font-family:var(--disp);font-weight:600;font-size:15px;color:var(--forest);line-height:1.15}
  .pillar .p-d{font-size:11.5px;color:var(--ink-soft);margin-top:6px;line-height:1.4}
  .pillar::before{content:"";display:block;width:26px;height:3px;border-radius:3px;background:var(--gold);margin-bottom:9px}

  .social-table{width:100%;border-collapse:collapse}
  .social-table thead th{font-family:var(--label);text-transform:uppercase;letter-spacing:.06em;font-size:11px;font-weight:600;
    color:var(--ink-soft);text-align:left;padding:10px 12px;border-bottom:2px solid var(--line-strong)}
  .social-table td{padding:12px;border-bottom:1px solid var(--line);vertical-align:top;font-size:13.5px}
  .social-table tr:hover td{background:var(--cream)}
  .s-date-cell{white-space:nowrap;font-weight:600;color:var(--forest)}
  .s-date-cell .dow{display:block;font-family:var(--label);font-size:10px;color:var(--ink-faint);text-transform:uppercase;font-weight:600}
  .status-sel{border:1px solid var(--line-strong);border-radius:8px;padding:5px 8px;background:var(--white);font-weight:600;font-size:12px}
  .pill-status{font-family:var(--label);text-transform:uppercase;letter-spacing:.04em;font-size:10px;font-weight:600;padding:3px 9px;border-radius:20px}
  .st-planned{background:#eef0ea;color:var(--ink-soft)}
  .st-shoot{background:#e9e2f3;color:#5a4178}
  .st-editing{background:var(--gold-wash);color:#7a5a06}
  .st-ready{background:#e7efe1;color:var(--forest)}
  .st-posted{background:var(--forest);color:#eaf0e4}
  .social-cards{display:none}
  @media(max-width:760px){
    .social-table thead{display:none}
    .social-table,.social-table tbody,.social-table tr,.social-table td{display:block;width:100%}
    .social-table tr{border:1px solid var(--line);border-radius:12px;margin-bottom:12px;background:var(--white);padding:6px}
    .social-table td{border:none;padding:6px 12px}
    .social-table td::before{content:attr(data-l);font-family:var(--label);text-transform:uppercase;font-size:10px;
      color:var(--ink-faint);font-weight:600;display:block;margin-bottom:2px}
  }

  /* ---------- Notes ---------- */
  .notes-grid{grid-template-columns:1.4fr .9fr}
  @media(max-width:860px){.notes-grid{grid-template-columns:1fr}}
  .notepad{width:100%;min-height:420px;border:1px solid var(--line);border-radius:14px;padding:20px;background:var(--cream);
    font-size:14.5px;line-height:1.7;resize:vertical;outline:none;color:var(--ink);
    background-image:repeating-linear-gradient(transparent,transparent 31px,var(--line) 31px,var(--line) 32px);
    background-attachment:local;line-height:32px}
  .notepad:focus{box-shadow:0 0 0 3px var(--gold-wash)}
  .ref-card{background:var(--forest);color:#eef0e6;border-radius:16px;padding:22px;margin-bottom:16px}
  .ref-card h3{font-family:var(--disp);font-weight:600;font-size:18px;color:var(--gold-soft);margin-bottom:12px}
  .ref-card ul{list-style:none;display:flex;flex-direction:column;gap:11px}
  .ref-card li{font-size:13px;line-height:1.5;padding-left:18px;position:relative;color:#dde4d4}
  .ref-card li::before{content:"";position:absolute;left:0;top:7px;width:7px;height:7px;border-radius:50%;background:var(--gold)}
  .ref-card li b{color:#fff;font-weight:600}

  /* ---------- Modal ---------- */
  .overlay{position:fixed;inset:0;background:rgba(28,28,20,.5);backdrop-filter:blur(3px);z-index:80;
    display:none;align-items:flex-start;justify-content:center;padding:40px 16px;overflow-y:auto}
  .overlay.open{display:flex}
  .modal{background:var(--cream);border-radius:18px;width:100%;max-width:520px;box-shadow:var(--shadow-lg);
    animation:pop .2s ease;overflow:hidden}
