    date:document.getElementById('taskDate').value,prio:document.getElementById('taskPrio').value,
    notes:document.getElementById('taskNotes').value.trim()};
  if(tid){ Object.assign(state.tasks.find(x=>x.id===tid),data); }
  else { state.tasks.push({id:id(),done:false,...data}); }
  save(); closeModal(); renderTasks(); renderDashboard(); renderCalendar();
}
function deleteTask(){ const tid=document.getElementById('taskId').value; state.tasks=state.tasks.filter(x=>x.id!==tid); save(); closeModal(); renderTasks(); renderDashboard(); renderCalendar(); }

