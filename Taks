/* ----- Calendar ----- */
function renderCalendar(){
  const first=new Date(2026,6,1); const startDow=first.getDay(); const days=31;
  const today=todayJulyStr();
  let cells=[]; for(let i=0;i<startDow;i++) cells.push(null);
  for(let d=1;d<=days;d++) cells.push(d);
  while(cells.length%7) cells.push(null);
  let html='';
  for(let w=0;w<cells.length/7;w++){
    html+='<tr>';
    for(let i=0;i<7;i++){
      const d=cells[w*7+i];
      if(d===null){ html+='<td class="empty"></td>'; continue; }
      const ds='2026-07-'+String(d).padStart(2,'0');
      const isWeekend=(i===0||i===6);
      const items=dayItems(ds);
      const shown=items.slice(0,3);
      const extra=items.length-shown.length;
      html+=`<td class="${isWeekend?'weekend':''}"><div class="cell ${ds===today?'has-today':''}" onclick="openDay('${ds}')">
        <div class="daynum">${d}${ds===today?'<span class="today-pill">Today</span>':''}</div>
        <div class="chips">
          ${shown.map(it=>`<span class="chip chip-${it.cls} ${it.done?'done':''}">${esc(it.label)}</span>`).join('')}
          ${extra>0?`<span class="more">+${extra} more</span>`:''}
        </div></div></td>`;
    }
    html+='</tr>';
  }
  document.getElementById('calBody').innerHTML=html;
}
function dayItems(ds){
  const out=[];
  state.events.filter(e=>e.date===ds).forEach(e=>out.push({cls:e.type==='shoot'?'shoot':e.type==='catering'?'cat':'event',label:e.title,done:false}));
  state.tasks.filter(t=>t.date===ds).forEach(t=>out.push({cls:t.domain==='marketing'?'mkt':'cat',label:t.title,done:t.done}));
  state.posts.filter(p=>p.date===ds).forEach(p=>out.push({cls:'social',label:'📷 '+p.pillar,done:p.status==='posted'}));
  return out;
}

