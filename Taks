/* ---------- state + persistence ---------- */
let state = null;
let saveTimer = null, notesTimer = null;

function id(){return 'x'+Math.random().toString(36).slice(2,9)}

async function loadState(){
  try{
    if(window.storage && window.storage.get){
      const r = await window.storage.get(STORAGE_KEY,false);
      if(r && r.value) return JSON.parse(r.value);
    }
  }catch(e){/* no saved state yet */}
  return null;
}
async function persist(){
  setSave('saving');
  try{
    if(window.storage && window.storage.set){
      await window.storage.set(STORAGE_KEY, JSON.stringify(state), false);
      setSave('saved');
    } else { setSave('local'); }
  }catch(e){ setSave('local'); }
}
function save(){ clearTimeout(saveTimer); saveTimer = setTimeout(persist, 350); }
function setSave(s){
  const pill=document.getElementById('savePill'), txt=document.getElementById('saveText');
  pill.classList.toggle('saved', s==='saved');
  txt.textContent = s==='saving'?'Saving…' : s==='saved'?'Saved' : 'Export to keep';
}

/* ---------- helpers ---------- */
function fmtDate(d){ const dt=new Date(d+'T00:00'); return DOW[dt.getDay()]+' '+(dt.getMonth()+1)+'/'+dt.getDate(); }
function dayNum(d){ return new Date(d+'T00:00').getDate(); }
function dowOf(d){ return DOW[new Date(d+'T00:00').getDay()]; }
function esc(s){ return (s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }
function todayJulyStr(){ const t=new Date(); return (t.getFullYear()===2026 && t.getMonth()===6) ? t.toISOString().slice(0,10) : null; }

