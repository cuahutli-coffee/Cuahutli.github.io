function deleteEvent(){ const eid=document.getElementById('eventId').value; state.events=state.events.filter(x=>x.id!==eid); save(); closeModal(); renderCalendar(); renderDashboard(); }

/* Day modal */
function openDay(ds){
  openOverlay('dayModal');
  const dt=new Date(ds+'T00:00');
  document.getElementById('dayModalTitle').textContent=DOW[dt.getDay()]+', July '+dt.getDate();
  const body=document.getElementById('dayBody');
  const evs=state.events.filter(e=>e.date===ds);
  const tks=state.tasks.filter(t=>t.date===ds);
  const pos=state.posts.filter(p=>p.date===ds);
  let h='';
  if(!evs.length&&!tks.length&&!pos.length){ h=`<div class="empty"><p>Nothing scheduled. Add something below.</p></div>`; }
  if(evs.length){ h+=`<div style="margin-bottom:14px"><div class="t-cat" style="color:var(--ink-soft);margin-bottom:8px">Events &amp; shoots</div>`+
    evs.map(e=>`<div class="task" style="margin-bottom:7px;cursor:pointer" onclick="closeModal();setTimeout(()=>openEvent('${e.id}'),60)">
      <span class="tag tag-${e.type==='catering'?'event':e.type}">${e.type}</span>
      <div class="t-main"><div class="t-title" style="font-size:13.5px">${esc(e.title)}</div>${e.notes?`<div class="t-notes">${esc(e.notes)}</div>`:''}</div></div>`).join('')+`</div>`; }
  if(tks.length){ h+=`<div style="margin-bottom:14px"><div class="t-cat" style="color:var(--ink-soft);margin-bottom:8px">Tasks due</div>`+
    tks.map(t=>`<div class="task ${t.done?'done':''}" style="margin-bottom:7px">
      <button class="check" onclick="toggleTask('${t.id}');openDay('${ds}')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg></button>
      <div class="t-main" style="cursor:pointer" onclick="closeModal();setTimeout(()=>openTask(null,'${t.id}'),60)"><div class="t-title" style="font-size:13.5px">${esc(t.title)}</div>
      <div class="t-meta"><span class="tag tag-${t.domain==='marketing'?'mkt':'cat'}">${t.domain}</span> <span class="t-cat">${esc(t.cat)}</span></div></div></div>`).join('')+`</div>`; }
  if(pos.length){ h+=`<div><div class="t-cat" style="color:var(--ink-soft);margin-bottom:8px">Posts</div>`+
    pos.map(p=>`<div class="task" style="margin-bottom:7px;cursor:pointer" onclick="closeModal();setTimeout(()=>openPost('${p.id}'),60)">
      <span class="tag tag-social">${esc(p.platform)}</span>
      <div class="t-main"><div class="t-title" style="font-size:13.5px">${esc(p.pillar)}</div><div class="t-notes">${esc(p.idea)}</div></div></div>`).join('')+`</div>`; }
  body.innerHTML=h;
  document.getElementById('dayAddTask').onclick=()=>{ closeModal(); setTimeout(()=>{ openTask('marketing'); document.getElementById('taskDate').value=ds; },60); };
  document.getElementById('dayAddEvent').onclick=()=>{ closeModal(); setTimeout(()=>openEvent(null,ds),60); };
  document.getElementById('dayAddPost').onclick=()=>{ closeModal(); setTimeout(()=>openPost(null,ds),60); };
}

/* ============================================================
   IMPORT / EXPORT
   ============================================================ */
function exportData(){
  const blob=new Blob([JSON.stringify(state,null,2)],{type:'application/json'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
  a.download='lake-roots-july2026-'+new Date().toISOString().slice(0,10)+'.json'; a.click();
}
function importData(ev){
  const f=ev.target.files[0]; if(!f) return;
  const r=new FileReader();
  r.onload=()=>{ try{ const d=JSON.parse(r.result); if(d.tasks&&d.posts){ state=d; save(); renderAll(); loadNotes(); alert('Imported. Your plan is loaded.'); } else alert('That file doesn\u2019t look like a Lake Roots backup.'); }catch(e){ alert('Could not read that file.'); } };
  r.readAsText(f); ev.target.value='';
}

/* ============================================================
   TABS
   ============================================================ */
document.getElementById('tabs').addEventListener('click',e=>{
  const tab=e.target.closest('.tab'); if(!tab) return;
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  tab.classList.add('active');
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+tab.dataset.view).classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
});
document.getElementById('domainFilter').addEventListener('click',e=>{
  const b=e.target.closest('button'); if(!b)return;
  fDomain=b.dataset.d;
  document.querySelectorAll('#domainFilter button').forEach(x=>{x.classList.remove('on','mkt','cat');});
  b.classList.add('on'); if(fDomain==='marketing')b.classList.add('mkt'); if(fDomain==='catering')b.classList.add('cat');
  renderTasks();
});
document.getElementById('statusFilter').addEventListener('click',e=>{
  const b=e.target.closest('button'); if(!b)return; fStatus=b.dataset.s;
  document.querySelectorAll('#statusFilter button').forEach(x=>x.classList.remove('on')); b.classList.add('on'); renderTasks();
});
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeModal(); });

function loadNotes(){ document.getElementById('notepad').value=state.notes||''; }

/* ============================================================
   INIT
   ============================================================ */
(async function init(){
  const saved=await loadState();
  state = saved || seed();
  if(!saved) await persist();
  fillCats('marketing');
  renderAll();
  loadNotes();
})();
</script>
